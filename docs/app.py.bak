#!/usr/bin/env python3
from __future__ import annotations

import datetime as dt
import json
import os
import subprocess
import sys
from datetime import timedelta
from pathlib import Path
from typing import List, Optional, Tuple

import streamlit as st

ROOT = Path(__file__).resolve().parent
KB_DIR = ROOT / "kb"
RAW_DIR = KB_DIR / "raw"
WIKI_DIR = KB_DIR / "wiki"
OUTPUTS_DIR = KB_DIR / "outputs"
CLI_PATH = ROOT / "scripts" / "kb.py"
TMP_UPLOADS = ROOT / ".tmp_uploads"

DEFAULT_MODEL = "phi4-mini"

PREVIEWABLE = {
    ".md", ".txt", ".json", ".yaml", ".yml", ".xml", ".csv",
    ".html", ".htm", ".py", ".js", ".ts", ".sql", ".log",
    ".toml", ".ini", ".cfg", ".sh", ".bat",
}


# ---------------------------------------------------------------------------
# Filesystem helpers
# ---------------------------------------------------------------------------

def ensure_dirs() -> None:
    for p in [RAW_DIR, WIKI_DIR, OUTPUTS_DIR, KB_DIR / "index", RAW_DIR / "assets", TMP_UPLOADS]:
        p.mkdir(parents=True, exist_ok=True)


def scan_files(directory: Path, pattern: str = "**/*", files_only: bool = True) -> List[Path]:
    """Return files sorted newest-first. Always reads live from disk."""
    if not directory.exists():
        return []
    paths = list(directory.glob(pattern))
    if files_only:
        paths = [p for p in paths if p.is_file() and p.name != ".gitkeep"]
    paths.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return paths


def fmt_size(n: int) -> str:
    for unit in ("B", "KB", "MB", "GB"):
        if n < 1024:
            return f"{n:.0f} {unit}" if unit == "B" else f"{n:.1f} {unit}"
        n /= 1024
    return f"{n:.1f} TB"


def fmt_date(ts: float) -> str:
    return dt.datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M")


def file_meta(p: Path) -> dict:
    stat = p.stat()
    return {
        "name": p.name,
        "size": stat.st_size,
        "size_h": fmt_size(stat.st_size),
        "modified": stat.st_mtime,
        "modified_h": fmt_date(stat.st_mtime),
    }


# ---------------------------------------------------------------------------
# CLI / UI helpers
# ---------------------------------------------------------------------------

def run_kb(args: List[str]) -> Tuple[int, str, str]:
    cmd = [sys.executable, str(CLI_PATH), *args]
    proc = subprocess.run(cmd, cwd=ROOT, capture_output=True, text=True)
    output = (proc.stdout or "").strip()
    err = (proc.stderr or "").strip()
    combined = output + ("\n\n" + err if err else "")
    shown_cmd = " ".join([str(x) for x in cmd])
    return proc.returncode, combined.strip(), shown_cmd


def safe_name(name: str) -> str:
    allowed = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_."
    cleaned = "".join(ch if ch in allowed else "-" for ch in name.strip())
    while "--" in cleaned:
        cleaned = cleaned.replace("--", "-")
    cleaned = cleaned.strip("-.")
    return cleaned or f"upload-{dt.datetime.now().strftime('%Y%m%d%H%M%S')}"


def unique_path(path: Path) -> Path:
    if not path.exists():
        return path
    ts = dt.datetime.now().strftime("%Y%m%d%H%M%S")
    return path.with_name(f"{path.stem}-{ts}{path.suffix}")


def save_uploaded_to(dir_path: Path, files) -> List[Path]:
    saved = []
    for f in files:
        name = safe_name(f.name)
        dst = unique_path(dir_path / name)
        dst.write_bytes(f.getbuffer())
        saved.append(dst)
    return saved


def parse_written_path(output: str) -> Optional[Path]:
    marker = "Wrote:"
    for line in output.splitlines():
        if line.startswith(marker):
            maybe = line.replace(marker, "", 1).strip()
            p = Path(maybe)
            return p if p.exists() else None
    return None


def show_cmd_result(returncode: int, output: str, shown_cmd: str) -> None:
    if returncode == 0:
        st.success("Done")
    else:
        st.error(f"Command failed (exit {returncode})")

    with st.expander("Command details", expanded=(returncode != 0)):
        st.code(shown_cmd, language="bash")
        st.code(output or "(no output)")


# ---------------------------------------------------------------------------
# Ollama helpers
# ---------------------------------------------------------------------------

def ollama_is_running() -> bool:
    try:
        import urllib.request
        req = urllib.request.Request("http://127.0.0.1:11434/", method="GET")
        with urllib.request.urlopen(req, timeout=3):
            return True
    except Exception:
        return False


def ollama_models() -> List[str]:
    try:
        import urllib.request
        req = urllib.request.Request("http://127.0.0.1:11434/api/tags", method="GET")
        with urllib.request.urlopen(req, timeout=5) as resp:
            data = json.loads(resp.read().decode("utf-8"))
            return [m["name"] for m in data.get("models", [])]
    except Exception:
        return []


def pick_model(default: str, key: str) -> str:
    models = ollama_models()
    if models:
        idx = 0
        for i, m in enumerate(models):
            if m == default or m.startswith(default + ":"):
                idx = i
                break
        return st.selectbox("Model", options=models, index=idx, key=key)
    return st.text_input("Model", value=default, key=key)


# ---------------------------------------------------------------------------
# Sidebar  (auto-refreshes file counts every 5 seconds)
# ---------------------------------------------------------------------------

def render_sidebar() -> str:
    st.sidebar.title("Local KB")
    st.sidebar.caption("Ollama + Obsidian")

    if st.sidebar.button("Refresh", use_container_width=True, help="Re-scan files from disk"):
        st.rerun()

    # Ollama status
    alive = ollama_is_running()
    if alive:
        st.sidebar.success("Ollama: running", icon=None)
    else:
        st.sidebar.error("Ollama: not running")

    # Model selector
    models = ollama_models()
    if models:
        if "default_model" not in st.session_state:
            st.session_state.default_model = DEFAULT_MODEL
        idx = 0
        for i, m in enumerate(models):
            if m == st.session_state.default_model or m.startswith(st.session_state.default_model + ":"):
                idx = i
                break
        model = st.sidebar.selectbox("Default model", options=models, index=idx, key="sidebar_model")
        st.session_state.default_model = model
    else:
        model = st.sidebar.text_input("Default model", value=DEFAULT_MODEL)
        st.session_state.default_model = model

    st.sidebar.markdown("---")

    with st.sidebar:
        _sidebar_metrics()

    return model


@st.fragment(run_every=timedelta(seconds=5))
def _sidebar_metrics():
    """Live file counts that auto-refresh even without user interaction."""
    raw_count = len(scan_files(RAW_DIR))
    wiki_count = len(scan_files(WIKI_DIR, "*.md"))
    out_count = len(scan_files(OUTPUTS_DIR, "*.md"))

    st.metric("Raw files", raw_count)
    st.metric("Wiki pages", wiki_count)
    st.metric("Output files", out_count)

    st.caption(f"Last scan: {dt.datetime.now().strftime('%H:%M:%S')}")


# ---------------------------------------------------------------------------
# Tabs — Ingest / Compile / Ask / Lint  (unchanged logic, minor polish)
# ---------------------------------------------------------------------------

def tab_ingest_files() -> None:
    st.subheader("Ingest Local Files")
    uploaded = st.file_uploader(
        "Upload source files",
        accept_multiple_files=True,
        help="Saves uploaded files into kb/raw/",
    )

    if st.button("Save uploaded files", use_container_width=True):
        if not uploaded:
            st.warning("Select at least one file first.")
        else:
            with st.spinner("Saving files..."):
                saved = save_uploaded_to(RAW_DIR, uploaded)
            st.success(f"Saved {len(saved)} file(s) to kb/raw")
            for p in saved[:20]:
                st.write(f"- `{p.name}`")

    st.markdown("---")
    st.caption("Or ingest files by path/glob from the machine running this app.")
    path_globs = st.text_area(
        "Path globs (one per line)",
        value="",
        placeholder="/Users/you/Research/*.md\n/Users/you/Research/*.txt",
    )
    if st.button("Ingest by path", use_container_width=True):
        lines = [ln.strip() for ln in path_globs.splitlines() if ln.strip()]
        if not lines:
            st.warning("Add at least one path/glob.")
        else:
            with st.spinner("Ingesting files..."):
                rc, out, cmd = run_kb(["ingest", *lines])
            show_cmd_result(rc, out, cmd)


def tab_ingest_url() -> None:
    st.subheader("Ingest URLs")
    urls_text = st.text_area(
        "URLs (one per line)",
        placeholder="https://example.com\nhttps://arxiv.org/abs/...",
        height=140,
    )
    col1, col2, col3 = st.columns(3)
    with col1:
        dl_images = st.checkbox("Download images", value=False)
    with col2:
        max_images = st.number_input("Max images", min_value=1, max_value=200, value=20, step=1)
    with col3:
        timeout = st.number_input("Timeout (seconds)", min_value=5, max_value=300, value=30, step=5)

    if st.button("Ingest URL(s)", use_container_width=True):
        urls = [u.strip() for u in urls_text.splitlines() if u.strip()]
        if not urls:
            st.warning("Add at least one URL.")
        else:
            args = ["ingest-url", *urls, "--timeout", str(timeout), "--max-images", str(max_images)]
            if dl_images:
                args.append("--download-images")
            with st.spinner(f"Fetching {len(urls)} URL(s)..."):
                rc, out, cmd = run_kb(args)
            show_cmd_result(rc, out, cmd)


def tab_ingest_pdf() -> None:
    st.subheader("Ingest PDFs")
    st.caption("Extracts text from PDF(s) into markdown files in kb/raw/")

    uploaded = st.file_uploader("Upload PDF files", type=["pdf"], accept_multiple_files=True)
    col1, col2 = st.columns(2)
    with col1:
        max_pages = st.number_input("Max pages (0 = all)", min_value=0, max_value=5000, value=0, step=1)
    with col2:
        copy_original = st.checkbox("Copy original PDF into kb/raw", value=False)

    if st.button("Extract PDF text", use_container_width=True):
        if not uploaded:
            st.warning("Upload at least one PDF first.")
            return

        saved = save_uploaded_to(TMP_UPLOADS, uploaded)
        args = ["ingest-pdf", *[str(p) for p in saved]]
        if max_pages > 0:
            args += ["--max-pages", str(max_pages)]
        if copy_original:
            args.append("--copy-original")

        with st.spinner(f"Extracting text from {len(saved)} PDF(s)..."):
            rc, out, cmd = run_kb(args)
        show_cmd_result(rc, out, cmd)

        for tmp in saved:
            try:
                tmp.unlink(missing_ok=True)
            except Exception:
                pass


def tab_compile(default_model: str) -> None:
    st.subheader("Compile Wiki")
    model = pick_model(default_model, key="compile_model")
    force = st.checkbox("Force recompile all docs", value=False)

    if st.button("Run compile", type="primary", use_container_width=True):
        args = ["compile", "--model", model]
        if force:
            args.append("--force")
        with st.status("Compiling wiki pages...", expanded=True) as status:
            rc, out, cmd = run_kb(args)
            if rc == 0:
                status.update(label="Compile complete", state="complete")
            else:
                status.update(label="Compile failed", state="error")
        show_cmd_result(rc, out, cmd)


def tab_ask(default_model: str) -> None:
    st.subheader("Ask the Wiki")
    question = st.text_area(
        "Question",
        placeholder="What are the recurring claims about retrieval quality?",
        height=120,
    )
    col1, col2 = st.columns([2, 1])
    with col1:
        model = pick_model(default_model, key="ask_model")
    with col2:
        limit = st.number_input("Page limit", min_value=1, max_value=30, value=6, step=1)

    if st.button("Run Q&A", type="primary", use_container_width=True):
        if not question.strip():
            st.warning("Please enter a question.")
            return
        args = ["ask", question.strip(), "--model", model, "--limit", str(limit)]
        with st.status("Thinking...", expanded=True) as status:
            rc, out, cmd = run_kb(args)
            if rc == 0:
                status.update(label="Answer ready", state="complete")
            else:
                status.update(label="Q&A failed", state="error")
        show_cmd_result(rc, out, cmd)

        written = parse_written_path(out)
        if written:
            answer_text = written.read_text(encoding="utf-8", errors="ignore")
            st.markdown("### Answer preview")
            st.markdown(answer_text)

            st.download_button(
                "Download answer (.md)",
                data=answer_text,
                file_name=written.name,
                mime="text/markdown",
            )

            if "qa_history" not in st.session_state:
                st.session_state.qa_history = []
            st.session_state.qa_history.insert(0, {
                "question": question.strip(),
                "file": written.name,
                "time": dt.datetime.now().strftime("%Y-%m-%d %H:%M"),
            })

    if st.session_state.get("qa_history"):
        with st.expander("Recent Q&A history"):
            for entry in st.session_state.qa_history[:10]:
                st.caption(f"**{entry['time']}** - {entry['question'][:80]}")
                hist_path = OUTPUTS_DIR / entry["file"]
                if hist_path.exists():
                    st.download_button(
                        f"Download {entry['file']}",
                        data=hist_path.read_text(encoding="utf-8", errors="ignore"),
                        file_name=entry["file"],
                        mime="text/markdown",
                        key=f"dl_{entry['file']}",
                    )


def tab_lint() -> None:
    st.subheader("Lint Wiki")
    st.caption("Checks broken markdown links and orphan pages.")
    if st.button("Run lint", use_container_width=True):
        with st.spinner("Linting wiki..."):
            rc, out, cmd = run_kb(["lint"])
        show_cmd_result(rc, out, cmd)


# ---------------------------------------------------------------------------
# Explorer tab — redesigned
# ---------------------------------------------------------------------------

def _explorer_file_table(files: List[Path], base_dir: Path) -> list[dict]:
    """Build a table of file metadata for display."""
    rows = []
    for p in files:
        try:
            meta = file_meta(p)
            meta["rel"] = str(p.relative_to(base_dir))
            rows.append(meta)
        except Exception:
            continue
    return rows


def _explorer_section(
    label: str,
    directory: Path,
    pattern: str,
    filter_key: str,
    pick_key: str,
    dl_key: str,
    allow_delete: bool = True,
    delete_hint: str = "",
) -> None:
    """Render one section of the Explorer (raw / wiki / outputs)."""
    files = scan_files(directory, pattern)

    if not files:
        st.info(f"No {label.lower()} yet.")
        return

    # --- Filter bar ---
    col_filter, col_sort = st.columns([3, 1])
    with col_filter:
        filt = st.text_input(
            f"Search {label.lower()}",
            placeholder="Type to filter by name...",
            key=filter_key,
            label_visibility="collapsed",
        )
    with col_sort:
        sort = st.selectbox(
            "Sort",
            options=["Newest first", "Oldest first", "Name A-Z", "Name Z-A", "Largest first"],
            key=f"{filter_key}_sort",
            label_visibility="collapsed",
        )

    # Apply filter
    if filt:
        files = [p for p in files if filt.lower() in p.name.lower()]

    if not files:
        st.caption("No files match the filter.")
        return

    # Apply sort
    if sort == "Oldest first":
        files.sort(key=lambda p: p.stat().st_mtime)
    elif sort == "Name A-Z":
        files.sort(key=lambda p: p.name.lower())
    elif sort == "Name Z-A":
        files.sort(key=lambda p: p.name.lower(), reverse=True)
    elif sort == "Largest first":
        files.sort(key=lambda p: p.stat().st_size, reverse=True)
    # else: already newest first from scan_files

    # --- File table ---
    rows = _explorer_file_table(files, directory)
    display_data = {
        "File": [r["rel"] for r in rows],
        "Size": [r["size_h"] for r in rows],
        "Modified": [r["modified_h"] for r in rows],
    }

    st.dataframe(
        display_data,
        use_container_width=True,
        hide_index=True,
        height=min(len(rows) * 35 + 38, 400),
    )
    st.caption(f"{len(files)} file(s)")

    # --- Detail pane: pick a file to preview / download / delete ---
    options = [r["rel"] for r in rows]
    selected = st.selectbox(
        "Select file",
        options=options,
        key=pick_key,
        label_visibility="collapsed",
    )

    if not selected:
        return

    path = directory / selected
    if not path.exists():
        st.warning("File no longer exists on disk. Click Refresh in the sidebar.")
        return

    meta = file_meta(path)

    # Metadata bar
    st.caption(f"`{selected}`  |  {meta['size_h']}  |  Modified {meta['modified_h']}")

    # Preview
    if path.suffix.lower() in PREVIEWABLE:
        content = path.read_text(encoding="utf-8", errors="ignore")
        with st.expander("Preview", expanded=True):
            if len(content) > 15000:
                st.caption(f"Showing first 15,000 of {len(content):,} characters")
            st.code(content[:15000], language="markdown" if path.suffix == ".md" else None)
    else:
        content = None
        st.caption(f"Binary file ({path.suffix}) — preview not available")

    # Action buttons
    btn_cols = st.columns(3 if allow_delete else 2)
    with btn_cols[0]:
        if content is not None:
            st.download_button(
                "Download",
                data=content,
                file_name=path.name,
                mime="text/plain",
                key=dl_key,
                use_container_width=True,
            )
        else:
            st.download_button(
                "Download",
                data=path.read_bytes(),
                file_name=path.name,
                mime="application/octet-stream",
                key=dl_key,
                use_container_width=True,
            )
    with btn_cols[1]:
        if st.button("Open in OS", key=f"open_{pick_key}", use_container_width=True,
                      help="Open the containing folder"):
            folder = str(path.parent)
            if sys.platform == "win32":
                os.startfile(folder)  # type: ignore[attr-defined]
            elif sys.platform == "darwin":
                subprocess.Popen(["open", folder])
            else:
                subprocess.Popen(["xdg-open", folder])

    if allow_delete:
        with btn_cols[2]:
            if f"confirm_del_{pick_key}" not in st.session_state:
                st.session_state[f"confirm_del_{pick_key}"] = False

            if not st.session_state[f"confirm_del_{pick_key}"]:
                if st.button("Delete", key=f"del_{pick_key}", type="secondary", use_container_width=True):
                    st.session_state[f"confirm_del_{pick_key}"] = True
                    st.rerun()
            else:
                st.warning(delete_hint or "This cannot be undone.", icon=None)
                c1, c2 = st.columns(2)
                with c1:
                    if st.button("Confirm delete", key=f"yes_del_{pick_key}", type="primary",
                                 use_container_width=True):
                        try:
                            path.unlink()
                            st.session_state[f"confirm_del_{pick_key}"] = False
                            st.toast(f"Deleted {path.name}")
                            st.rerun()
                        except Exception as e:
                            st.error(f"Could not delete: {e}")
                with c2:
                    if st.button("Cancel", key=f"no_del_{pick_key}", use_container_width=True):
                        st.session_state[f"confirm_del_{pick_key}"] = False
                        st.rerun()


def tab_explorer() -> None:
    st.subheader("File Explorer")

    explorer_tabs = st.tabs([
        f"Raw files ({len(scan_files(RAW_DIR))})",
        f"Wiki pages ({len(scan_files(WIKI_DIR, '*.md'))})",
        f"Outputs ({len(scan_files(OUTPUTS_DIR, '*.md'))})",
    ])

    with explorer_tabs[0]:
        _explorer_section(
            label="Raw files",
            directory=RAW_DIR,
            pattern="**/*",
            filter_key="raw_filter",
            pick_key="raw_pick",
            dl_key="dl_raw",
            allow_delete=True,
            delete_hint="Source file will be removed. Run Compile with Force to refresh wiki.",
        )

    with explorer_tabs[1]:
        _explorer_section(
            label="Wiki pages",
            directory=WIKI_DIR,
            pattern="*.md",
            filter_key="wiki_filter",
            pick_key="wiki_pick",
            dl_key="dl_wiki",
            allow_delete=True,
            delete_hint="Wiki page will be removed. Compile may recreate it from source.",
        )

    with explorer_tabs[2]:
        _explorer_section(
            label="Output files",
            directory=OUTPUTS_DIR,
            pattern="*.md",
            filter_key="out_filter",
            pick_key="out_pick",
            dl_key="dl_out",
            allow_delete=True,
            delete_hint="This output file will be permanently deleted.",
        )


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    ensure_dirs()
    st.set_page_config(page_title="Local KB", page_icon="📚", layout="wide")
    st.title("📚 Local Knowledge Base")
    st.caption("Your own personal library, complete with an AI librarian")

    default_model = render_sidebar()

    tabs = st.tabs([
        "Ingest Files",
        "Ingest URL",
        "Ingest PDF",
        "Compile",
        "Ask",
        "Lint",
        "Explorer",
    ])

    with tabs[0]:
        tab_ingest_files()
    with tabs[1]:
        tab_ingest_url()
    with tabs[2]:
        tab_ingest_pdf()
    with tabs[3]:
        tab_compile(default_model)
    with tabs[4]:
        tab_ask(default_model)
    with tabs[5]:
        tab_lint()
    with tabs[6]:
        tab_explorer()


if __name__ == "__main__":
    main()
